{
  "manifest_version": 3,
  "name": "Echo-Fetch Link Interceptor",
  "version": "1.0.0",
  "description": "Capture links and send to Echo-Fetch Download Manager",
  "permissions": [
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Echo-Fetch"
  }
}